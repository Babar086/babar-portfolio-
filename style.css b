body {
  margin: 0;
  font-family: Arial;
  background: #f5f6fa;
}

header {
  display: flex;
  justify-content: space-between;
  background: #111;
  color: white;
  padding: 15px 30px;
  align-items: center;
}

.logo {
  font-size: 22px;
  font-weight: bold;
}

nav a {
  color: white;
  margin: 0 10px;
  text-decoration: none;
}

.hero {
  text-align: center;
  padding: 60px;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  color: white;
}

.ad-box {
  margin: 20px auto;
  width: 80%;
  padding: 20px;
  background: #ddd;
  text-align: center;
  border: 2px dashed #888;
}

.posts {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 15px;
  padding: 20px;
}

.post {
  background: white;
  padding: 15px;
  border-radius: 10px;
  box-shadow: 0 0 10px rgba(0,0,0,0.1);
  transition: 0.3s;
}

.post:hover {
  transform: scale(1.05);
}

footer {
  text-align: center;
  background: #111;
  color: white;
  padding: 10px;
}
